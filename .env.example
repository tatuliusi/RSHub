# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=tax_chunks

# Redis
REDIS_URL=redis://localhost:6379/0

# Langfuse (optional - leave blank to disable tracing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Model config
PLANNER_MODEL=claude-haiku-4-5-20251001
SYNTHESIZER_MODEL=claude-sonnet-4-6
CRITIC_MODEL=claude-haiku-4-5-20251001

# Retrieval config
HYBRID_ALPHA=0.65
TOP_K_RETRIEVAL=20
TOP_K_FINAL=5
MAX_CRITIC_ITERATIONS=3


# Embedding
BGE_M3_MODEL=BAAI/bge-m3
BGE_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
BGE_M3_DEVICE=cpu

# Cache
SEMANTIC_CACHE_THRESHOLD=0.92
CACHE_TTL_SECONDS=86400

# API
API_HOST=0.0.0.0
API_PORT=8000
RATE_LIMIT_PER_MINUTE=10

# Scraper schedule (cron format)
SCRAPER_TAX_CODE_CRON=0 2 * * *
SCRAPER_RS_GE_CRON=0 */6 * * *

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
